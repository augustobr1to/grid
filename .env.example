# Copy to .env (gitignored) and adjust. These are the env vars the apps read.

# --- Server (apps/server) ---
# Port the Colyseus + Express server listens on.
PORT=2567

# --- Game client (apps/game, Vite — must be prefixed VITE_) ---
# WebSocket URL of the Colyseus server. If unset, the client defaults to
# ws(s)://<current-host>:2567, which is correct for local dev but not for a
# deployment where the server lives on a different host.
# VITE_COLYSEUS_URL=wss://your-server.example.com
